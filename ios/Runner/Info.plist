	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<!-- Copied from REVERSED_CLIENT_ID in GoogleService-Info.plist -->
				<string>com.googleusercontent.apps.326808345238-1lp0uag72hdjbjf6c3hqsr5tsl365n3v</string>
			</array>
		</dict>
	</array>
	<!-- End of the Google Sign-in Section -->

	<key>UIApplicationSceneManifest</key>
	<dict>
